      <Description>"Sprint Speed Modifier 2"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
aobscanmodule(INJECT,AVGame-Win64-Shipping.exe, F3 0F 11 BF 14 04 ?? ?? F3 44 0F 11 87 9C 04 ?? ??)
