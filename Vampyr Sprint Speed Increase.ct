        <CheatEntry>
          <ID>86974</ID>
          <Description>"Shift"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
-- Prevent syntax check from executing runtime code
if syntaxcheck then return end

if speedThread then
  speedThread.terminate()
  speedThread = nil
end

speedThread = createThread(function(thread)
  while not thread.terminated do
    -- local shiftDown = (isKeyPressed(VK_SHIFT) == true)
    local shiftDown = true
    local playerAddr = getAddress("pPlayer")
    local playerBase = readPointer(playerAddr)

    if playerBase and shiftDown then
      writeFloat(playerBase + 0x414, 1000.0)
    end

    sleep(10)
  end
end)

[DISABLE]
{$lua}
-- stop the Lua thread if it exists
if speedThread then
    speedThread.terminate()
    speedThread = nil

end

    local playerAddr = getAddress("pPlayer")
    local playerBase = readPointer(playerAddr)
    if playerBase then
      writeFloat(playerBase + 0x414, 400.0)
    end
</AssemblerScript>
